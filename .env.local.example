# ════════════════════════════════════════════════════════
#  POPPYPINK — Environment Variables
#  Copy this file → .env.local  and fill in real values
# ════════════════════════════════════════════════════════

# ── 1. Clerk Auth ─────────────────────────────────────
#  Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

#  Redirect paths (keep as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── 2. MongoDB ─────────────────────────────────────────
#  Get from: https://cloud.mongodb.com (free M0 cluster)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/poppypink

# ── 3. Admin Access ────────────────────────────────────
#  Comma-separated admin emails
ADMIN_EMAILS=youremail@gmail.com

# ── 4. Web3Forms ──────────────────────────────────────
NEXT_PUBLIC_WEB3FORMS_KEY=REPLACE_ME
